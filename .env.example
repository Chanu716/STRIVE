# STRIVE environment template
# Copy this file to .env and fill in any secrets before running the API or docker compose.

# PostgreSQL connection string used by app/db/session.py.
# Use localhost when running the API directly; docker-compose overrides this to db:5432.
DATABASE_URL=postgresql://strive:strive@localhost:5432/strive

# OpenWeatherMap API key used by app/weather.py.
# The API falls back to clear-weather defaults when this is unset.
OWM_API_KEY=your_api_key_here

# Optional compatibility name from the task sheet. Keep it in sync with OWM_API_KEY if used.
OPENWEATHERMAP_API_KEY=your_api_key_here

# Path to the pre-downloaded OSM road graph used by M4 routing.
GRAPH_PATH=data/raw/road_network.graphml

# Paths to the trained M2 model and feature metadata used by M3/M4 inference.
MODEL_PATH=models/model.pkl
FEATURE_CONFIG_PATH=models/feature_config.json

# Optional MLflow tracking URI for training/evaluation scripts.
MLFLOW_TRACKING_URI=mlruns

# API runtime configuration for local scripts or process managers.
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false

# Logging level for local runs.
LOG_LEVEL=INFO
