# Environment variables for STRIVE

# OpenWeatherMap API
OWM_API_KEY=your_api_key_here

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/strive
# Or for local development with SQLite:
# DATABASE_URL=sqlite:///./strive.db

# Model paths
MODEL_PATH=models/model.pkl
FEATURE_CONFIG_PATH=models/feature_config.json

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Routing configuration
ALPHA_DEFAULT=0.6
CACHE_MAX_AGE=300

# Logging
LOG_LEVEL=INFO

# Flask/Debugging (development only)
DEBUG=false
